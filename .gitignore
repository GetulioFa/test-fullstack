# ==========================================
# GITIGNORE GLOBAL PARA MONOREPO (Fullstack)
# Escopo: .NET 10 e React 18 (Vite / Create React App)
# ==========================================

# ------------------------------------------
# 1. ARQUIVOS E PASTAS DO SISTEMA OPERACIONAL
# ------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ------------------------------------------
# 2. AMBIENTES DE DESENVOLVIMENTO (IDEs / Editores)
# ------------------------------------------
# Visual Studio
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo

# Visual Studio Code
.vscode/
!.vscode/extensions.json
.history/

# JetBrains (Rider, WebStorm)
.idea/
*.sln.iml

# ------------------------------------------
# 3. BACKEND (.NET 10 / C#)
# ------------------------------------------
# Pastas de compilação e saída de binários
[Bb]in/
[Oo]bj/
[An]y[Cc]PU/
[Xx]64/
[Xx]84/

# Artefatos do MSBuild e ferramentas de publicação
*.publish.htm
*.azure.publishsettings
appsettings.Development.json
appsettings.Local.json

# Cache do gerenciador de pacotes (NuGet)
project.lock.json
project.fragment.lock.json
artifacts/

# Testes e Cobertura de Código
*.CodeAnalysisLog.xml
*.lastcodeanalysissucceeded
TestResults/
*.trx
*.coverlet.core.attributes.cs

# Banco de dados local/desenvolvimento (SQLite por exemplo)
*.db
*.db-shm
*.db-wal

# ------------------------------------------
# 4. FRONTEND (React 18 / Node.js)
# ------------------------------------------
# Dependências do ecossistema Node
node_modules/
jspm_packages/

# Pastas de build e distribuição (Vite, CRA)
dist/
build/
out/

# Logs do NPM, Yarn e PNPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Arquivos de variáveis de ambiente (Crucial ignorar por segurança!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Cache de ferramentas do Frontend (Eslint, Vite)
.eslintcache
.vite/
.turbo/
coverage/

# ------------------------------------------
# 5. CONFIGURAÇÕES ADICIONAIS / DIVERSOS
# ------------------------------------------
# Logs gerais
*.log
chrome_debug.log